# CareerIQ Pro — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development — works out of the box, no setup):
USE_SQLITE=true
SQLITE_URL=sqlite:///./careeriq_prod.db

# PostgreSQL (production on Render — paste the Internal DB URL from Render dashboard):
# USE_SQLITE=false
# DATABASE_URL=postgresql://careeriq:password@dpg-xxxxx.render.com:5432/careeriq_db

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Gemini AI (for Interview Prep + ATS AI suggestions):
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Auth / Security ──────────────────────────────────────────────────────────
SECRET_KEY=careeriq-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── ML Model Paths ───────────────────────────────────────────────────────────
SALARY_MODEL_PATH=salary_model.pkl
JOB_MATCHER_PATH=job_matcher.pkl

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true
PORT=8000

# ─── PII / Privacy ────────────────────────────────────────────────────────────
PII_REMOVAL_ENABLED=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production (replace with your Vercel URL):
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://careeriq.vercel.app

# ─── Debug ────────────────────────────────────────────────────────────────────
DB_ECHO=false
