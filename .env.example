# ─────────────────────────────────────────────────────────────────────────────
# CareerIQ Pro — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=CareerIQ Pro
APP_VERSION=1.0.0

# ── Security (CHANGE IN PRODUCTION) ──────────────────────────────────────────
SECRET_KEY=careeriq-dev-secret-change-in-production-minimum-32-chars
ANONYMIZATION_SALT=careeriq-anon-salt-change-this-too

# ── Database ──────────────────────────────────────────────────────────────────
# Set USE_SQLITE=true for local development (zero config)
# Set USE_SQLITE=false for production with PostgreSQL
USE_SQLITE=true
DATABASE_URL=postgresql://careeriq:careeriq_pass@localhost:5432/careeriq_db
DB_ECHO=false

# ── Redis (optional for development) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── External Job APIs (optional — platform works without these) ───────────────
# Adzuna: https://developer.adzuna.com
ADZUNA_APP_ID=57d260ec
ADZUNA_API_KEY=a063c15c522051b494f8031771b5c650

# JSearch via RapidAPI: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# GitHub (for portfolio project validation)
GITHUB_TOKEN=

# ── ML / AI Configuration ─────────────────────────────────────────────────────
# Leave SALARY_MODEL_PATH empty to use built-in CNN regression
SALARY_MODEL_PATH=salary_model.pkl
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NLP_MODEL=en_core_web_sm
ML_BATCH_SIZE=32
SALARY_CONFIDENCE_THRESHOLD=0.65

# ── Privacy ───────────────────────────────────────────────────────────────────
PII_REMOVAL_ENABLED=true
ENCRYPT_RESUME_STORAGE=true
DATA_RETENTION_DAYS=365

# ── Frontend (React) ──────────────────────────────────────────────────────────
# Set this in frontend/.env (create separately)
# REACT_APP_API_URL=http://localhost:8000
